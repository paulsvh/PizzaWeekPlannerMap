# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# --- Server-only secrets ------------------------------------------------

# The passcode you share with friends to log into the app.
# Pick something easy to share verbally but not guessable.
APP_PASSCODE=

# A random 32+ byte secret used to sign session JWTs.
# Generate one with: openssl rand -base64 32
SESSION_SECRET=

# Firebase service account credentials.
# In the Firebase console: Project settings → Service accounts → Generate new private key.
# The JSON file contains these three fields.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# For the private key, paste the whole "-----BEGIN PRIVATE KEY-----..." value.
# Locally, the literal \n inside is fine — env.ts converts them at runtime.
# On Vercel, paste with real newlines in the Environment Variables UI.
FIREBASE_PRIVATE_KEY=

# --- Client-exposed (NEXT_PUBLIC_) --------------------------------------

# Google Maps JavaScript API key, restricted by HTTP referrer to your
# Vercel domain + http://localhost:3000/*.
# APIs needed: Maps JavaScript API, Directions API.
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=
