# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# --- Server-only secrets ------------------------------------------------

# A random 32+ byte secret used to sign session JWTs.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=

# The fully-qualified URL of the app. Used to build invite links that
# get sent in emails and copied in the admin panel.
#   Local dev:     http://localhost:3000
#   Production:    https://your-vercel-domain.vercel.app
APP_URL=http://localhost:3000

# Firebase service account credentials.
# In the Firebase console: Project settings → Service accounts → Generate new private key.
# The JSON file contains these three fields.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# For the private key, paste the whole "-----BEGIN PRIVATE KEY-----..." value.
# Locally, the literal \n inside is fine — env.ts converts them at runtime.
# On Vercel, paste with real newlines in the Environment Variables UI.
FIREBASE_PRIVATE_KEY=

# Google Places API (New) key — SERVER-side only.
# Used by scripts/scrape-everout.ts to look up restaurant addresses and
# coordinates by name. Create a SEPARATE key from the browser Maps key:
#   GCP Console → Credentials → Create credentials → API key
#   Restrict to: Places API (New)
#   Application restriction: None (Node can't send HTTP referrers)
GOOGLE_PLACES_SERVER_KEY=

# --- Resend email delivery (optional) -----------------------------------
# If BOTH of these are set, invite emails are sent automatically via
# Resend when an admin creates an invite. If either is missing, the
# admin panel still works — it just shows a copy-link button instead
# of sending an email, and the admin shares the invite link manually.
#
# To enable email delivery:
#   1. Sign up at https://resend.com
#   2. Verify a domain you own (add the DNS records Resend gives you)
#   3. Generate an API key in the Resend dashboard
#   4. Set the two vars below — RESEND_FROM_EMAIL must be @yourdomain

RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Client-exposed (NEXT_PUBLIC_) --------------------------------------

# Google Maps JavaScript API key, restricted by HTTP referrer to your
# Vercel domain + http://localhost:3000/*.
# APIs needed: Maps JavaScript API, Directions API.
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=
